{
  "_comment": "Copy to probes.local.json (gitignored) and fill in real dev credentials. Each key is a profile name referenced by a service's probe.profile in YAML. Never commit the real file.",
  "example-api-key": {
    "baseUrl": "https://service.dev.example.com",
    "auth": { "kind": "api-key", "header": "x-api-key", "value": "<dev x-api-key>" }
  },
  "example-bearer": {
    "baseUrl": "https://api.dev.example.com",
    "auth": { "kind": "bearer", "token": "<dev bearer JWT>" }
  },
  "example-oauth": {
    "baseUrl": "https://gateway.dev.example.com",
    "auth": {
      "kind": "oauth-client-credentials",
      "tokenUrl": "https://auth.dev.example.com/oauth/token",
      "basic": "<base64 client_id:secret>"
    }
  }
}
